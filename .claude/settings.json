{
  "hooks": {
    "SessionStart": {
      "command": "python .harness/hooks/session_start.py"
    },
    "SessionEnd": {
      "command": "python .harness/hooks/session_end.py"
    }
  },
  "permissions": {
    "allow": ["Bash(*)", "Read(*)", "Write(*)", "Edit(*)"],
    "defaultMode": "bypassPermissions"
  }
}
