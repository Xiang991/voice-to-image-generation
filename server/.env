


# 选择你要使用的llm 取消注释并填写其 key

# DEEPSEEK_API_KEY=sk-your-key-here
# QWEN_API_KEY=your-dashscope-api-key
# GLM_API_KEY=your-glm-api-key  # 格式: xxxxxxxx.xxxxxxxxxxxxxxxx
# MOONSHOT_API_KEY=your-moonshot-api-key

MODEL=deepseek-v4-flash  #填写对应模型的名字 例如 deepseek-v4-flash

# 讯飞语音识别 (语音听写 IAT)
XUNFEI_APP_ID=your-xunfei-app-id
XUNFEI_API_KEY=your-xunfei-api-key
XUNFEI_API_SECRET=your-xunfei-api-secret
